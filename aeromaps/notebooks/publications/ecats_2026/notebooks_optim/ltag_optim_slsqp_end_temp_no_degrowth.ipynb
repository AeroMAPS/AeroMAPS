    "      \"    INFO - 12:58:27:    with respect to lcaf_mandate_share_values_optim, saf_co2_mandate_share_values_optim, saf_ftg_mandate_share_values_optim\\n\",\n",
    "      \"    INFO - 12:58:27:    under the inequality constraints\\n\",\n",
