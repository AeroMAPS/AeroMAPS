    "    \"### Optimisation problem setup with GEMSEO\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 34,\n",
    "   \"metadata\": {\n",
