    "      \"    INFO - 21:57:19:    minimize cumulative_co2_2060(saf_co2_mandate_share_values_optim, saf_ftg_mandate_share_values_optim, lcaf_mandate_share_values_optim)\\n\",\n",
    "      \"    INFO - 21:57:19:    with respect to lcaf_mandate_share_values_optim, saf_co2_mandate_share_values_optim, saf_ftg_mandate_share_values_optim\\n\",\n",
    "      \"    INFO - 21:57:19:    under the inequality constraints\\n\",\n",
    "      \"    INFO - 21:57:19:       saf_co2_use_growth_constraint(saf_co2_mandate_share_values_optim, saf_ftg_mandate_share_values_optim, lcaf_mandate_share_values_optim) <= 0\\n\",\n",
