    "      \"    INFO - 17:59:16:    minimize mean_temperature_increase_from_aviation_2025_end(saf_co2_mandate_share_values_optim, saf_ftg_mandate_share_values_optim, lcaf_mandate_share_values_optim)\\n\",\n",
    "      \"    INFO - 17:59:16:    with respect to lcaf_mandate_share_values_optim, saf_co2_mandate_share_values_optim, saf_ftg_mandate_share_values_optim\\n\",\n",
    "      \"    INFO - 17:59:16:    under the inequality constraints\\n\",\n",
    "      \"    INFO - 17:59:16:       saf_co2_use_growth_constraint(saf_co2_mandate_share_values_optim, saf_ftg_mandate_share_values_optim, lcaf_mandate_share_values_optim) <= 0\\n\",\n",
