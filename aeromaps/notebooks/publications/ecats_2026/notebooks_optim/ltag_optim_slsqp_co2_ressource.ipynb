    "   \"source\": [\n",
    "    \"### Optimisation problem setup with GEMSEO\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 5,\n",
    "   \"metadata\": {\n",
    "    \"tags\": []\n",
    "   },\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from gemseo.algos.design_space import DesignSpace\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"from gemseo.settings.opt import COBYQA_Settings\\n\",\n",
    "    \"from gemseo.settings.opt import SLSQP_Settings\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create a GEMSEO scenario\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"process_is2medium.gemseo_settings[\\\"scenario_type\\\"] = \\\"MDO\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Define the design space: direct absolute shares (0-100) for SAF FTG, SAF CO2, and LCAF\\n\",\n",
    "    \"# Targeted years for optimization variables: 2035, 2040, 2045, 2050, 2055, 2060, 2065, 2070\\n\",\n",
    "    \"# The kerosene share is implicit: 100 - (FTG + CO2 + LCAF). Completeness is ensured via a constraint.\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"design_space = DesignSpace()\\n\",\n",
    "    \"\\n\",\n",
    "    \"design_space.add_variable(\\n\",\n",
    "    \"    \\\"saf_co2_mandate_share_values_optim\\\",\\n\",\n",
    "    \"    size=8,\\n\",\n",
    "    \"    lower_bound=[1e-17] * 8,\\n\",\n",
    "    \"    upper_bound=[100] * 8,\\n\",\n",
    "    \"    value=[4.0, 4.0, 4.0, 4.0, 4.0, 4.0, 4.0, 4.0],\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"design_space.add_variable(\\n\",\n",
    "    \"    \\\"saf_ftg_mandate_share_values_optim\\\",\\n\",\n",
    "    \"    size=8,\\n\",\n",
    "    \"    lower_bound=[1e-17] * 8,\\n\",\n",
    "    \"    upper_bound=[100] * 8,\\n\",\n",
    "    \"    value=[4.0, 4.0, 4.0, 4.0, 4.0, 4.0, 4.0, 4.0],\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"design_space.add_variable(\\n\",\n",
    "    \"    \\\"lcaf_mandate_share_values_optim\\\",\\n\",\n",
    "    \"    size=8,\\n\",\n",
    "    \"    lower_bound=[1e-17] * 8,\\n\",\n",
    "    \"    upper_bound=[100] * 8,\\n\",\n",
    "    \"    value=[4.0, 4.0, 4.0, 4.0, 4.0, 4.0, 4.0, 4.0],\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"process_is2medium.gemseo_settings[\\\"design_space\\\"] = design_space\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Define the objective\\n\",\n",
    "    \"objective_name = \\\"cumulative_co2_end_year\\\"  # ,cumulative_co2_end_year, temperature_increase_end_year, mean_temperature_increase_from_aviation_2025_end\\n\",\n",
    "    \"process_is2medium.gemseo_settings[\\\"objective_name\\\"] = objective_name\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"process_is2medium.create_gemseo_scenario()\\n\",\n",
    "    \"# Make optimisation objective values in the 1-10 interval\\n\",\n",
    "    \"process_is2medium.scenario.formulation.optimization_problem.objective = (\\n\",\n",
    "    \"    process_is2medium.scenario.formulation.optimization_problem.objective\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Add constraints (include blend_completeness_constraint with direct shares)\\n\",\n",
    "    \"all_constraints = [\\n\",\n",
    "    \"    \\\"biomass_trajectory_constraint\\\",\\n\",\n",
    "    \"    \\\"generic_electricity_trajectory_constraint\\\",\\n\",\n",
    "    \"    \\\"saf_co2_use_growth_constraint\\\",\\n\",\n",
    "    \"    \\\"saf_ftg_use_growth_constraint\\\",\\n\",\n",
    "    \"    \\\"lcaf_use_growth_constraint\\\",\\n\",\n",
    "    \"    \\\"blend_completeness_constraint\\\",\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"for constraint in all_constraints:\\n\",\n",
    "    \"    process_is2medium.scenario.add_constraint(constraint, constraint_type=\\\"ineq\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"process_is2medium.scenario.set_differentiation_method(\\\"finite_differences\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"slsqp_settings = SLSQP_Settings(\\n\",\n",
    "    \"    max_iter=500,\\n\",\n",
    "    \"    ftol_rel=0.00001,\\n\",\n",
    "    \"    ftol_abs=0.00001,\\n\",\n",
    "    \"    ineq_tolerance=0.05,\\n\",\n",
    "    \"    normalize_design_space=True,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"process_is2medium.gemseo_settings[\\\"algorithm\\\"] = slsqp_settings  # cobyla_settings\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Adding design variables to the set of list types varaible (they are declared as ndarray but needed as lists within aeromaps functions)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"CustomDataConverter._list_names.update(process_is2medium.scenario.get_optim_variable_names())\"\n",
    "   ]\n",
